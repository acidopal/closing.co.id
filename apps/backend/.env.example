# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Application Configuration
NODE_ENV=development
PORT=3010
APP_MODE=api
SOCKET_PORT=3011
SOCKET_IO_PATH=/socket.io
SOCKET_IO_TRANSPORTS=websocket
SOCKET_IO_CORS_ORIGIN=https://local-fe.scalebiz.chat,http://localhost:3005

# Xendit Payment Integration
# Get your API keys from https://dashboard.xendit.co/settings/developers#api-keys
XENDIT_SECRET_KEY=xnd_development_...
# Token used for verifying callback payloads (new name for clarity)
XENDIT_CALLBACK_TOKEN=your_callback_token_here
# URL that Xendit will post webhook events to
XENDIT_WEBHOOK_URL=http://localhost:3010/api/xendit/webhook
XENDIT_WEBHOOK_TOKEN=your_webhook_token_here
XENDIT_RECONCILIATION_ENABLED=true

# Application URL (for Xendit callbacks)
APP_URL=http://localhost:3010

# Meta webhook callback URL override (optional).
# Use this when webhook ingress host is different from main API host.
# Example: https://webhook-api.scalebiz.chat/api/v1/webhooks/whatsapp
WHATSAPP_WEBHOOK_CALLBACK_URL=

# n8n Automation Integration
N8N_BASE_URL=http://localhost:3309
N8N_API_KEY=your_n8n_api_key_here
N8N_USER_SECRET=your_secret_for_deriving_n8n_passwords
N8N_EMBED_AUTH_ENABLED=true
N8N_EMBED_AUTH_SECRET=your_embed_auth_shared_secret
# Optional: app secret used for non-ScaleBiz embedded credentials
N8N_EMBED_APP_SECRET=your_embed_app_secret
# Required for ScaleBiz credentials in embedded n8n
N8N_EMBED_SCALEBIZ_API_KEY=your_scalebiz_api_key
# Optional: defaults to /rest/embedded-auth/scalebiz/login
N8N_EMBED_AUTH_PATH=/rest/embedded-auth/scalebiz/login
# Optional: rewrite forwarded cookie Domain for cross-subdomain iframe auth
N8N_EMBED_COOKIE_DOMAIN=.scalebiz.chat

# TikTok OAuth / Messaging
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://api.scalebiz.chat/api/tiktok-channels/callback
# Comma/space separated. Example:
# TIKTOK_SCOPES=user.info.basic
# Note: inbound DM still requires TikTok messaging product/webhook approval.
TIKTOK_SCOPES=user.info.basic

# Object Storage (S3-compatible)
# Either use S3_* / AWS_* variables, or Cloudflare R2 variables below.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_URL=

# Cloudflare R2 (alternative)
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
