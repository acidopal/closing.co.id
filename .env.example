# ScaleChat Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:3010

# App Credentials (REQUIRED for authentication)
# Get these from your backend: GET /api/apps
# Default credentials (CHANGE IN PRODUCTION!):
VITE_APP_ID=app_cb437a519e1ca0c706db11e70ab470b6
VITE_APP_SECRET=scalesecret

# Socket.IO Configuration
VITE_SOCKET_URL=http://localhost:3010
VITE_SOCKET_PATH=/socket.io

# Feature Flags
VITE_ENABLE_AI=true
VITE_ENABLE_FORMS=true
VITE_ENABLE_SALES_PIPELINE=true
