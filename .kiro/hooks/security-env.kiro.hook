{
  "enabled": true,
  "name": "Environment File Validation",
  "description": "Check .env files for accidentally committed secrets",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/.env*"
    ]
  },
  "steps": [
    {
      "command": "echo 'Verify .env file is in .gitignore and contains no production secrets'",
      "description": "Remind to check env file security"
    }
  ]
}
